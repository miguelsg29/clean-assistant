# Clean Assistant — configuración (copia a .env). El .env NO se sube a git.
#
# Sin CONGA_MODE=real, arranca con un robot SIMULADO (no hace falta configurar nada).
#
# PARA TU CONGA REAL (lo más fácil): pon CONGA_MODE=real y DEJA LOS IDs COMO ESTÁN.
# En el primer arranque, Clean Assistant se conecta a la nube (pasarela) y CAPTURA
# SOLO la identidad del robot (DID, userid, SN, MAC...), la guarda en identity.json
# y pasa a modo local automáticamente. Solo necesitas: redirigir el DNS de
# tcp-cecotec.3irobotix.net a este equipo y reiniciar el robot (corte de luz).
# Si prefieres, puedes rellenar los IDs a mano (salen del login capturado con MITM).

CONGA_MODE=mock

# --- Identificadores de TU robot (opcionales: se autocapturan en el primer arranque) ---
ROBOT_DID=123456
ROBOT_USERID=654321
ROBOT_SN=500400000000
ROBOT_MAC=12:34:56:78:9A:BC
FACTORY_ID=1003
PROJECT_TYPE=CECOTECCRL350-1001
LISTEN_PORT=9090

# --- Certificados TLS (se generan solos con openssl si no existen) ---
CERT_PATH=cert.pem
KEY_PATH=key.pem

# --- JWT del login: vacío = sintético automático (recomendado, el robot no lo valida) ---
AUTH_JWT=

# --- Puente MQTT para Home Assistant (OPCIONAL) ---
# Si defines MQTT_HOST, Clean Assistant publica el robot en HA por autodiscovery,
# además de la web (una sola conexión al robot). Déjalo vacío para no usar MQTT.
MQTT_HOST=
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
# Valores por defecto que HA mostrará en los selectores al arrancar:
DEFAULT_FAN=Normal
DEFAULT_WATER=Medio
DEFAULT_MOP=Estándar
